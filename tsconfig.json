{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "strict": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@lib/worker/bgWorker.ts": ["./livesync-commonlib/src/worker/bgWorker.mock.ts"],
      "@lib/worker/bgWorker": ["./livesync-commonlib/src/worker/bgWorker.mock.ts"],
      "@lib/pouchdb/pouchdb-browser.ts": ["./livesync-commonlib/src/pouchdb/pouchdb-http.ts"],
      "@lib/pouchdb/pouchdb-browser": ["./livesync-commonlib/src/pouchdb/pouchdb-http.ts"],
      "@lib/*": ["./livesync-commonlib/src/*"],
      "@/lib/src/UI/DialogHost.svelte": ["./stubs/svelte-stub.ts"],
      "@/lib/src/*": ["./livesync-commonlib/src/*"],
      "@/common/*": ["./stubs/common/*"],
      "@/deps": ["./stubs/deps.ts"],
      "@/deps.ts": ["./stubs/deps.ts"],
      "@/main": ["./stubs/main.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "stubs/**/*.ts",
    "livesync-commonlib/src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
