so the previous utils.ts fix had no effect on the actual splitting code path.

Co-Authored-By: Claude Sonnet 4.6 <noreply@anthropic.com>
---
 src/string_and_binary/chunks.ts | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/string_and_binary/chunks.ts b/src/string_and_binary/chunks.ts
index 32d4097..c7c0bbe 100644
--- a/src/string_and_binary/chunks.ts
+++ b/src/string_and_binary/chunks.ts
@@ -1,5 +1,5 @@
 function isTextBlob(blob: Blob) {
-    return blob.type === "text/plain";
+    return blob.type === "text/plain" || blob.type.startsWith("text/plain;");
 }
 
 import { LOG_LEVEL_VERBOSE, Logger } from "../common/logger.ts";
